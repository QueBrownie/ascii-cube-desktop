#!/bin/sh
# bspwmrc — window manager config
# No bars. No decorations. Ctrl+T opens a terminal. That's it.

# ── Hotkey daemon ──────────────────────────────────────────────────────────────
pgrep -x sxhkd > /dev/null || sxhkd &

# ── Workspaces ─────────────────────────────────────────────────────────────────
bspc monitor -d 1 2 3 4 5

# ── Window appearance ──────────────────────────────────────────────────────────
bspc config border_width          2
bspc config window_gap            0

bspc config normal_border_color   "#333333"
bspc config focused_border_color  "#00ff41"
bspc config presel_border_color   "#003300"

# ── Behaviour ──────────────────────────────────────────────────────────────────
bspc config focus_follows_pointer true
bspc config pointer_follows_focus false

# ── Floating — all windows open as resizable floating windows ──────────────────
bspc rule -a '*' state=floating
bspc config pointer_modifier mod4
bspc config pointer_action1 move
bspc config pointer_action3 resize_corner

# ── Compositor ─────────────────────────────────────────────────────────────────
picom --config ~/.config/picom/picom.conf --daemon &

# ── Desktop cube ───────────────────────────────────────────────────────────────
~/.config/cube/launch_cube.sh &
