#!/bin/sh
# bspwmrc — window manager config
# No bars. No decorations. Ctrl+T opens a terminal. That's it.

# ── Hotkey daemon ──────────────────────────────────────────────────────────────
pgrep -x sxhkd > /dev/null || sxhkd &

# ── Workspaces ─────────────────────────────────────────────────────────────────
bspc monitor -d 1 2 3 4 5

# ── Window appearance ──────────────────────────────────────────────────────────
bspc config border_width          1
bspc config window_gap            0

# Nearly invisible borders — just enough to see window edges
bspc config normal_border_color   "#111111"
bspc config focused_border_color  "#00ff41"
bspc config presel_border_color   "#003300"

# ── Behaviour ──────────────────────────────────────────────────────────────────
bspc config split_ratio           0.52
bspc config borderless_monocle    true
bspc config gapless_monocle       true
bspc config focus_follows_pointer false
bspc config pointer_follows_focus false

# ── Compositor ─────────────────────────────────────────────────────────────────
picom --config ~/.config/picom/picom.conf --daemon &

# ── Desktop cube ───────────────────────────────────────────────────────────────
~/.config/cube/launch_cube.sh &
